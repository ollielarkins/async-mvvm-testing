<UserControl x:Class="MyWpfApp.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- HEADER -->
            <TextBlock Text="sync/async mvvm demo"
                       FontSize="30"
                       FontWeight="Bold"
                       Margin="0 0 0 20"
                       HorizontalAlignment="Center"/>

            <!-- TAP TEST -->
            <Border Style="{StaticResource GlassCard}">
                <StackPanel>
                    <TextBlock Text="async test" FontSize="20"/>
                    <Button Content="click" Command="{Binding IncreaseTapCommand}" PreviewMouseRightButtonDown="OnRightClick" Margin="0 10"/>
                    <TextBlock Text="{Binding TapCount, StringFormat=taps: {0}}" FontSize="16"/>
                </StackPanel>
            </Border>

            <!-- STATUS -->
            <Border Style="{StaticResource GlassCard}">
                <StackPanel>
                    <TextBlock Text="status" FontSize="20"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="16"/>
                    <TextBlock Text="{Binding EtaText}" FontSize="14" Foreground="#888"/>
                    <TextBlock Text="{Binding DebugText}" FontSize="12" Foreground="Red"/>
                </StackPanel>
            </Border>

            <!-- PROGRESS -->
            <Border Style="{StaticResource GlassCard}">
                <StackPanel>
                    <TextBlock Text="progress" FontSize="20"/>
                    <ProgressBar Height="12"
                                 Minimum="0" Maximum="100"
                                 Margin="0 10 0 5"
                                 Value="{Binding ProgressPercent}"/>
                    <TextBlock Text="{Binding ProgressPercent, StringFormat={}{0:F0}%}"
                               HorizontalAlignment="Right"/>
                </StackPanel>
            </Border>

            <!-- CONTROLS -->
            <Border Style="{StaticResource GlassCard}">
                <StackPanel>

                    <TextBlock Text="controls" FontSize="20"/>

                    <Button Content="start async"
                            Command="{Binding RunAsyncCommand}"
                            Style="{StaticResource AccentButton}"
                            Margin="0 10"/>

                    <Button Content="start sync"
                            Command="{Binding RunBlockingCommand}"
                            Margin="0 10"/>

                    <Button Content="reset"
                            Command="{Binding ResetCommand}"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
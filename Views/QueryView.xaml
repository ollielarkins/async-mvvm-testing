<UserControl x:Class="MyWpfApp.Views.QueryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource GlassCard}">
        <StackPanel>

            <TextBlock Text="mock db query" FontSize="22"/>

            <TextBox Text="{Binding QueryText}"
                     Height="100"
                     Margin="0 10"
                     AcceptsReturn="True"/>

            <Button Content="run" 
                    Command="{Binding RunQueryCommand}" />

            <Border Margin="10" Padding="10" Background="#11000000">
                <ItemsControl ItemsSource="{Binding QueryResults}"/>
            </Border>

        </StackPanel>
    </Border>

</UserControl>
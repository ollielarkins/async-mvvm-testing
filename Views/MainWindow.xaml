<Window x:Class="MyWpfApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MyWpfApp.Views"
        xmlns:vm="clr-namespace:MyWpfApp.ViewModels"
        Title="mvvm long task test"
        Width="1000" Height="650"
        Background="White">

    <Window.Resources>

        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <local:DashboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:TablesViewModel}">
            <local:TablesView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:QueryViewModel}">
            <local:QueryView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <local:LogsView />
        </DataTemplate>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <local:SidebarView Grid.Column="0"/>

        <!-- Active view -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}" />
    </Grid>

</Window>